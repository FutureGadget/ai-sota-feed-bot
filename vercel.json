{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "llm-digest.com" }],
      "destination": "https://www.llm-digest.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/llms.txt", "destination": "/web/llms.txt" },
    { "source": "/llm-guide.txt", "destination": "/web/llm-guide.txt" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=3600" }
      ]
    }
  ],
  "functions": {
    "api/feed.js": {
      "includeFiles": "data/{processed/**,tier1/{latest,runs_index}.json}",
      "excludeFiles": "data/{raw/**,llm/**,digest/**,health/**,cache/**,diagnostics/**,feedback/**,analysis/**,tier1/runs/**}"
    },
    "api/rss.js": {
      "includeFiles": "data/{processed/**,tier1/{latest,runs_index}.json}",
      "excludeFiles": "data/{raw/**,llm/**,digest/**,health/**,cache/**,diagnostics/**,feedback/**,analysis/**,tier1/runs/**}"
    },
    "api/events.js": {
      "excludeFiles": "data/**"
    },
    "api/client-config.js": {
      "excludeFiles": "data/**"
    }
  }
}
